---
import { site, tagline } from '../data/site';
---

<section id="top" class="relative flex min-h-[100svh] flex-col justify-between overflow-hidden px-[var(--spacing-gutter)] pb-8 pt-20">
  <!-- top meta bar -->
  <div data-reveal class="flex flex-wrap items-center justify-between gap-x-4 gap-y-1 border-b border-ink pb-3 font-mono text-[0.65rem] uppercase tracking-[0.14em] sm:text-xs sm:tracking-[0.22em]">
    <span>
      <span class="sm:hidden">Vol. 01 / 2026</span>
      <span class="hidden sm:inline">Portfolio / Vol. 01 / 2026</span>
    </span>
    <span class="hidden sm:inline">{site.location} · 37.77°N</span>
  </div>

  <!-- name + portrait -->
  <div class="flex flex-1 items-center py-10">
    <div class="grid w-full grid-cols-1 items-center gap-10 md:grid-cols-12">
      <div class="md:col-span-8">
        <p data-reveal class="kicker mb-4 sm:mb-6">Software Engineer / AI · Graphics · Systems</p>
        <h1 class="display-x leading-[0.82] text-ink" style="font-size:clamp(3rem, 12vw, 13rem)">
          <span data-reveal class="block" style="--reveal-delay:60ms">Luis</span>
          <span data-reveal class="block" style="--reveal-delay:140ms">
            Aval<span class="relative inline-block">os<span class="absolute -bottom-1 left-0 h-[0.1em] w-full bg-accent"></span></span>
          </span>
        </h1>
      </div>

      <!-- portrait (keep a vertical crop) -->
      <div data-reveal class="md:col-span-4" style="--reveal-delay:220ms">
        <figure class="group relative mx-auto w-3/5 max-w-[16rem] sm:w-1/2 md:w-full md:max-w-[17rem]">
          <span class="absolute inset-0 translate-x-2 translate-y-2 rounded-[50%] bg-accent transition-transform duration-500 group-hover:scale-105" aria-hidden="true"></span>
          <img
            src="/portrait.jpg"
            alt="Luis Avalos"
            width="600"
            height="800"
            class="relative aspect-[4/5] w-full rounded-[50%] border-2 border-ink object-cover grayscale contrast-[1.05] shadow-none transition-[filter,transform,box-shadow] duration-500 group-hover:scale-105 group-hover:grayscale-0 group-hover:shadow-[0_0_2.5rem_0.25rem_var(--color-accent)]"
          />
        </figure>
      </div>
    </div>
  </div>

  <!-- intro grid -->
  <div class="grid grid-cols-1 gap-8 border-t border-ink pt-6 md:grid-cols-12 md:items-end">
    <div data-reveal class="md:col-span-7 lg:col-span-6">
      <p class="max-w-xl font-sans text-lg leading-snug sm:text-xl">
        I build <mark class="bg-accent px-1 text-ink">software that has to be right</mark>. Lately that’s a Claude agent that keeps a small business’s books, a platform running <strong class="font-semibold">billing for a real company</strong>, and a real-time terrain renderer in C++.
      </p>
      <div class="mt-6 flex flex-wrap items-center gap-3 font-mono text-xs uppercase tracking-widest">
        <a href="#work" class="group inline-flex items-center gap-2 border-2 border-ink bg-ink px-5 py-2.5 text-paper transition-colors duration-200 hover:bg-accent hover:text-ink">
          View Work <span class="transition-transform duration-200 group-hover:translate-y-0.5">↓</span>
        </a>
        <a href={`mailto:${site.email}`} class="inline-flex items-center gap-2 border-2 border-ink px-5 py-2.5 transition-colors duration-200 hover:bg-ink hover:text-paper">
          Get in touch
        </a>
      </div>
    </div>

    <dl data-reveal class="grid grid-cols-2 gap-x-6 gap-y-4 font-mono text-xs md:col-span-5 md:col-start-8 lg:col-span-4 lg:col-start-9">
      <div>
        <dt class="text-muted uppercase tracking-widest">Based in</dt>
        <dd class="mt-1 text-sm">{site.location}</dd>
      </div>
      <div>
        <dt class="text-muted uppercase tracking-widest">Focus</dt>
        <dd class="mt-1 text-sm">AI · Graphics</dd>
      </div>
      <div>
        <dt class="text-muted uppercase tracking-widest">Degree</dt>
        <dd class="mt-1 text-sm">B.S. CS · KSU</dd>
      </div>
      <div>
        <dt class="text-muted uppercase tracking-widest">Since</dt>
        <dd class="mt-1 text-sm">Shipping ’19</dd>
      </div>
    </dl>
  </div>
</section>
