---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
}
const { project }: Props = Astro.props;
const primary = project.links.live ?? (project.repoPrivate ? undefined : project.links.github);
const Tag = primary ? 'a' : 'div';
---

<Tag
  {...(primary ? { href: primary, target: '_blank', rel: 'noopener' } : {})}
  data-reveal
  class="group flex h-full flex-col border-2 border-ink bg-paper p-6 transition-colors duration-200 hover:bg-ink hover:text-paper"
>
  <div class="mb-4 flex items-center justify-between font-mono text-[0.7rem] uppercase tracking-[0.2em] text-muted group-hover:text-paper/70">
    <span><span class="text-ink group-hover:text-accent">[{project.num}]</span> {project.category}</span>
    <span class="transition-transform duration-200 group-hover:translate-x-1 group-hover:-translate-y-1">{primary ? '↗' : '·'}</span>
  </div>

  <h3 class="display-x text-2xl leading-none sm:text-3xl">{project.name}</h3>
  <p class="mt-3 text-sm leading-snug text-ink/80 group-hover:text-paper/80">{project.tagline}</p>

  <p class="mt-3 flex-1 text-sm leading-relaxed text-ink/70 group-hover:text-paper/70">{project.highlights[0]}</p>

  <div class="mt-5 flex items-center justify-between gap-3">
    <ul class="flex min-w-0 flex-wrap gap-1.5">
      {project.stack.slice(0, 3).map((s) => (
        <li class="border border-line px-2 py-0.5 font-mono text-[0.65rem] group-hover:border-paper/30">{s}</li>
      ))}
    </ul>
    <span class="min-w-0 shrink truncate text-right font-mono text-[0.65rem] uppercase tracking-widest text-muted group-hover:text-accent">{project.metric ? project.metric.split('·')[0].trim() : project.year}</span>
  </div>
</Tag>
