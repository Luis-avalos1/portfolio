---
import { site } from '../data/site';
---

<header class="fixed inset-x-0 top-0 z-40 border-b border-ink bg-paper/85 backdrop-blur-md">
  <nav class="mx-auto flex h-14 max-w-[1600px] items-center justify-between px-[var(--spacing-gutter)]">
    <a href="#top" aria-label="Luis Avalos — home" class="group -ml-1 flex min-h-11 items-center gap-2 px-1 font-display text-lg font-extrabold tracking-tight">
      <span class="grid h-7 w-7 place-items-center border-2 border-ink bg-accent text-sm transition-transform duration-300 group-hover:rotate-[-6deg]">LA</span>
      <span class="hidden sm:inline">LUIS AVALOS</span>
    </a>

    <div class="flex items-center gap-1 font-mono text-xs uppercase tracking-widest sm:gap-2">
      <a href="#work" class="link-underline hidden px-2 py-1 sm:inline-block">Work</a>
      <a href="#about" class="link-underline hidden px-2 py-1 sm:inline-block">About</a>
      <a href="#contact" class="link-underline hidden px-2 py-1 md:inline-block">Contact</a>
      <a
        href={site.resume}
        target="_blank"
        rel="noopener"
        class="ml-1 inline-flex min-h-11 items-center gap-1.5 border-2 border-ink bg-ink px-3 py-2.5 text-paper transition-colors duration-200 hover:bg-accent hover:text-ink sm:min-h-0 sm:py-1.5"
      >
        Résumé <span aria-hidden="true">↗</span>
      </a>
    </div>
  </nav>
</header>
